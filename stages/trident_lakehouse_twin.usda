        def Scope "Inventory"
        {
            def Scope "Camera"
            {
                custom string trident:entity_id = "inventory.namespace.camera"
                custom string trident:entity_type = "inventory_namespace"
                custom string trident:namespace = "camera"
                custom string trident:zone = "zone.lakehouse_inventory"

                def Xform "Frames"
                {
                    def Cube "TableCrate"
                    {
                        rel material:binding = </World/Materials/iceberg_box>
                        double size = 1
                        custom int trident:access_frequency = 42
                        custom string trident:component = "frames"
                        custom string trident:entity_id = "table.camera.frames"
                        custom string trident:entity_type = "iceberg_table"
                        custom string trident:freshness = "fresh"
                        custom bool trident:location_ready = 1
                        custom string trident:name = "camera.frames table crate"
                        custom string trident:namespace = "camera"
                        custom int trident:object_count = 380
                        custom bool trident:policy_ready = 1
                        custom float trident:quality_score = 0.91
                        custom float trident:readiness_score = 0.91
                        custom int trident:row_count = 12400000
                        custom bool trident:semantic_ready = 1
                        custom string trident:stage = "lakehouse_inventory"
                        custom string trident:workload_fit = "AI+HPDA"
                        custom string trident:zone = "zone.lakehouse_inventory"
                        float3 xformOp:scale = (0.82, 0.58, 0.48)
                        double3 xformOp:translate = (22, -4.9, 1.45)
                        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                    }

                    def "ReadinessBars"
                    {
                        def Cube "SchemaTable"
                        {
                            rel material:binding = </World/Materials/schema_bar>
                            double size = 1
                            custom string trident:entity_id = "table.camera.frames.bar.schematable"
                            custom string trident:entity_type = "readiness_bar"
                            custom string trident:name = "SchemaTable readiness bar"
                            custom float trident:readiness_score = 0.91
                            custom bool trident:ready = 1
