    def Scope "Environment"
    {
        def Cube "Floor"
        {
            rel material:binding = </World/Materials/floor>
            double size = 1
            float3 xformOp:scale = (110, 48, 0.1)
            double3 xformOp:translate = (25, 8, -0.05)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def DistantLight "SunLight"
        {
            float inputs:angle = 0.6
            float inputs:intensity = 3200
            float3 xformOp:rotateXYZ = (-50, 30, 0)
            uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
        }

        def DomeLight "SkyDome"
        {
            float inputs:intensity = 1100
        }
    }

