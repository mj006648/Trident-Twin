        <mxCell id="twin-view" value="&lt;b&gt;3D Twin View&lt;/b&gt;&#xa;&#xa;• Embedded WebRTC stream from Omniverse Server&#xa;&#xa;IN: WebRTC (UDP/Video)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2a1a;strokeColor=#44aa66;fontColor=#aaffcc;fontSize=10;verticalAlign=top;arcSize=8;align=left;spacingLeft=6;" vertex="1" parent="1">
