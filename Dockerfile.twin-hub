FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-twin-hub.txt ./
RUN pip install --no-cache-dir -r requirements-twin-hub.txt

COPY twin-hub ./twin-hub
COPY data ./data

WORKDIR /app/twin-hub
EXPOSE 8765

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8765"]
